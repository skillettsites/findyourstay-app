# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local db
/data/*.db
/data/*.db-*

# seeded photos live in object storage, not the repo
/public/places/

.vercel
.env*

# Outreach scraped data (personal info — never commit)
scripts/*.csv
scripts/france-raw.json

# E2E test artifacts (session tokens, screenshots, codes — never commit)
e2e/auth.json
e2e/otp.txt
e2e/_tour_status.txt
e2e/bug-report.md
e2e/tour/
